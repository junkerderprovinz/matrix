# =============================================================================
# .dockerignore — Matrix All-in-One
# Excludes files that should not be sent to the Docker build context.
# =============================================================================

# Git metadata
.git/
.gitignore

# Note: .github/ is intentionally NOT ignored — the init-log banner is sourced
# from .github/assets/banner-raw.txt (COPYd in the Dockerfile), matching the
# other own-image repos.

# Documentation — not needed inside the image
README.md
LICENSE

# Unraid template — not needed inside the image
unraid-template.xml

# OS junk
.DS_Store
Thumbs.db
*.swp
*.swo

# Local secrets and test data
*.env
.env
secrets/
data/

# Build artifacts
*.zip
*.tar.gz
*.log

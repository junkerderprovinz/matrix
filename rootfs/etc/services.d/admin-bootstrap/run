#!/command/with-contenv sh
# shellcheck shell=sh
# =============================================================================
# admin-bootstrap/run — one-shot service that creates the admin user
#
# Reads /data/.create_admin (written by 10-config.sh when ADMIN_USER and
# ADMIN_PASSWORD env vars are set), waits for Synapse to be ready on port 8008,
# then registers the user as admin using register_new_matrix_user.
#
# After successful creation, marks /data/.admin_created and removes the
# temporary credential file. The service then sleeps forever — s6 will not
# restart it (this is the simplest "run-once" pattern under s6-overlay v3).
# =============================================================================

set -u

# cd into /data — register_new_matrix_user loads homeserver.yaml which
# triggers Synapse's config validator; relative paths in the config get
# resolved against CWD, and the s6 service dir is read-only.
cd /data || { echo "[admin-bootstrap] FATAL: cannot cd into /data" >&2; exec sleep infinity; }

CRED_FILE="/data/.create_admin"
DONE_FILE="/data/.admin_created"

log() { printf '\033[0;36m[admin-bootstrap] %s\033[0m\n' "$*"; }

# Nothing to do? Sleep forever (s6 keeps service alive but idle)
if [ ! -f "$CRED_FILE" ]; then
    log "No credential file present — nothing to do."
    exec sleep infinity
fi

# Wait for Synapse to respond on /health (max 120s)
log "Waiting for Synapse to become ready on http://127.0.0.1:8008/health ..."
i=0
while [ $i -lt 60 ]; do
    if curl -fsS --max-time 2 -o /dev/null "http://127.0.0.1:8008/health" 2>/dev/null; then
        log "Synapse is ready."
        break
    fi
    i=$((i + 1))
    sleep 2
done

if [ $i -ge 60 ]; then
    log "WARNING: Synapse did not become ready within 120s — aborting admin creation."
    exec sleep infinity
fi

# Read credentials
USER=$(sed -n '1p' "$CRED_FILE")
PASS=$(sed -n '2p' "$CRED_FILE")

if [ -z "$USER" ] || [ -z "$PASS" ]; then
    log "ERROR: credentials file is malformed — skipping."
    rm -f "$CRED_FILE"
    exec sleep infinity
fi

log "Registering admin user '$USER' ..."
out=$(register_new_matrix_user \
        -c /data/homeserver.yaml \
        -u "$USER" \
        -p "$PASS" \
        -a \
        http://127.0.0.1:8008 2>&1)
rc=$?
[ -n "$out" ] && printf '%s\n' "$out"

if [ $rc -eq 0 ]; then
    log "Admin user '$USER' created successfully."
    : > "$DONE_FILE"
    rm -f "$CRED_FILE"
else
    # Only an explicit "already exists" answer from Synapse counts as done.
    # Any other non-zero rc (connection refused, wrong registration secret,
    # ...) must KEEP the credential file so the next restart retries.
    case "$out" in
        *"already taken"*|*M_USER_IN_USE*)
            # register_new_matrix_user -a only sets the server-admin flag when it
            # CREATES the account; for a pre-existing user (e.g. self-registered in
            # Element) it does nothing — so the account stays a normal user and
            # Synapse-Admin fails with "Server communication error" (403 on the
            # /_synapse/admin API). Promote it directly in Postgres, the documented
            # way to grant server admin. psycopg2 ships in the Synapse image and the
            # POSTGRES_* env is already present (with-contenv).
            log "User '$USER' already exists — ensuring it is a Synapse server admin ..."
            if python3 - "$USER" <<'PY'
import os, sys
import psycopg2
u = sys.argv[1]
name = u if u.startswith("@") else "@%s:%s" % (u, os.environ["SERVER_NAME"])
conn = psycopg2.connect(
    host=os.environ["POSTGRES_HOST"], port=os.environ.get("POSTGRES_PORT", "5432"),
    user=os.environ["POSTGRES_USER"], password=os.environ["POSTGRES_PASSWORD"],
    dbname=os.environ["POSTGRES_DB"])
cur = conn.cursor()
cur.execute("UPDATE users SET admin=1 WHERE name=%s", (name,))
conn.commit()
print("[admin-bootstrap] admin flag set for %s (rows matched: %d)" % (name, cur.rowcount))
PY
            then
                log "Ensured '$USER' is a server admin (Synapse-Admin will work after re-login)."
                : > "$DONE_FILE"
                rm -f "$CRED_FILE"
            else
                log "WARNING: could not reach Postgres to promote '$USER' — will retry on next restart."
            fi
            ;;
        *)
            log "ERROR: register_new_matrix_user failed with exit code $rc."
            log "Leaving credential file in place; will retry on next container restart."
            ;;
    esac
fi

# Service stays alive but idle — s6 considers this "running" so won't restart
exec sleep infinity

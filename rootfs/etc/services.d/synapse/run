#!/command/with-contenv sh
# shellcheck shell=sh
# =============================================================================
# s6 service: synapse
# Starts the Synapse Matrix homeserver process.
#
# s6-overlay v3 convention:
#   - This script must NOT background itself (no "&" or "exec ... &")
#   - s6 monitors the process; if it exits, s6 will restart it
#   - Use "exec" so s6 receives signals directly (no shell wrapper process)
# =============================================================================

# Resolve PUID/PGID with safe defaults (must match cont-init.d values)
PUID="${PUID:-99}"
PGID="${PGID:-100}"

# Synapse requires SYNAPSE_SERVER_NAME and SYNAPSE_CONFIG_PATH in its env.
# The config was generated by 10-config.sh on first boot.
export SYNAPSE_SERVER_NAME="${SERVER_NAME}"
export SYNAPSE_CONFIG_PATH="/data/homeserver.yaml"

# cd into /data so any relative paths Synapse may still resolve at runtime
# (rare, but defensive) anchor under the persistent volume rather than the
# read-only s6 service directory under /run/s6-rc:.../
cd /data || { echo "[synapse] FATAL: cannot cd into /data" >&2; exit 1; }

# Synapse's --config-path is repeatable (action="append" in its arg parser).
# We pass homeserver-overrides.yaml as a second config file so its database,
# OIDC, federation, TURN, etc. settings actually take effect. The previous
# include_config_files: directive inside homeserver.yaml is NOT a Synapse
# feature — Synapse silently ignored it, and all the overrides were dead
# config. See 10-config.sh comments for context.
exec gosu "${PUID}:${PGID}" \
    python -m synapse.app.homeserver \
        --config-path /data/homeserver.yaml \
        --config-path /data/homeserver-overrides.yaml \
        --keys-directory /data

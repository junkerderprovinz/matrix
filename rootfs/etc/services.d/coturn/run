#!/bin/sh
# =============================================================================
# s6 service: coturn
# Starts the coturn TURN/STUN server for Matrix voice/video calls.
#
# coturn reads its configuration from /data/turnserver.conf which is rendered
# from the template by 10-config.sh at container startup.
# =============================================================================

# Wait until turnserver.conf has been written by the init script.
# This handles the edge case where s6 starts services before cont-init.d finishes.
TURN_CONF="/data/turnserver.conf"
RETRIES=30
i=0
while [ ! -f "${TURN_CONF}" ]; do
    if [ "${i}" -ge "${RETRIES}" ]; then
        printf '[coturn] ERROR: %s not found after %d seconds, giving up.\n' "${TURN_CONF}" "${RETRIES}" >&2
        exit 1
    fi
    printf '[coturn] Waiting for %s ...\n' "${TURN_CONF}"
    sleep 1
    i=$((i + 1))
done

# Run coturn as root so it can open stdout/stderr inherited from s6 and bind
# privileged ports if needed. coturn drops privileges itself via the
# proc-user/proc-group directives in turnserver.conf (set to 'nobody').
# This is the coturn-native way to run as non-root and avoids the
# 'opening errorlog /dev/stderr failed: Permission denied' issue caused by
# gosu-dropping before coturn can inherit the supervisor's file descriptors.
exec /usr/bin/turnserver \
    --config "${TURN_CONF}" \
    --no-cli \
    --simple-log

# =============================================================================
# homeserver-overrides.yaml.tmpl
# Rendered by 10-config.sh via envsubst into /data/homeserver-overrides.yaml
# and included by homeserver.yaml via include_config_files.
#
# This file REPLACES / OVERRIDES the corresponding sections generated by
# --generate-config. It is re-rendered on every container start so that
# environment variable changes (e.g. new POSTGRES_* values) take effect
# without manually editing homeserver.yaml.
#
# Variables substituted:
#   ${POSTGRES_HOST}     — hostname or IP+port of the Postgres server
#   ${POSTGRES_PORT}     — Postgres port (default 5432)
#   ${POSTGRES_USER}     — database user
#   ${POSTGRES_PASSWORD} — database password
#   ${POSTGRES_DB}       — database name
#   ${SERVER_NAME}       — Matrix server name (e.g. matrix.example.com)
#   ${TURN_SECRET}       — shared TURN secret (generated on first boot)
# =============================================================================

# --- Database -----------------------------------------------------------------
# Use external Postgres. The database MUST have been created with:
#   CREATE DATABASE matrix
#     ENCODING 'UTF8'
#     LC_COLLATE='C'
#     LC_CTYPE='C'
#     TEMPLATE template0;
# Synapse strictly requires locale 'C' — any other locale causes startup failure.
database:
  name: psycopg2
  args:
    host: "${POSTGRES_HOST}"
    port: ${POSTGRES_PORT}
    user: "${POSTGRES_USER}"
    password: "${POSTGRES_PASSWORD}"
    database: "${POSTGRES_DB}"
    # cp_min / cp_max: connection pool size. Tune if you have many users.
    cp_min: 5
    cp_max: 10

# --- Media storage ------------------------------------------------------------
# Store media inside the persistent /data volume.
media_store_path: /data/media_store
# Maximum upload size in bytes (100 MB default — adjust to taste)
max_upload_size: 100M

# --- Logging ------------------------------------------------------------------
# Write logs to stdout so Docker / Unraid log viewer can capture them.
log_config: ""

# --- Performance tweaks -------------------------------------------------------
# These are conservative defaults suitable for a home server.
# Increase caches if you have > 100 concurrent users.
event_cache_size: 10K
caches:
  global_factor: 0.5

# --- Registration -------------------------------------------------------------
# Disable open registration by default — create accounts via register_new_matrix_user
# or Synapse-Admin with a registration token.
enable_registration: false
# Uncomment and set to true only for initial setup, then disable again.
# enable_registration_without_verification: false

# --- TURN / coturn ------------------------------------------------------------
# Points Synapse to our bundled coturn server for voice/video relay.
turn_uris:
  - "turn:${SERVER_NAME}:3478?transport=udp"
  - "turn:${SERVER_NAME}:3478?transport=tcp"
turn_shared_secret: "${TURN_SECRET}"
turn_user_lifetime: 86400000
turn_allow_guests: false

# --- Federation ---------------------------------------------------------------
# Allow federation with other Matrix homeservers (set to false for private use)
federation_domain_whitelist: ~

# --- URL Previews -------------------------------------------------------------
url_preview_enabled: true

# --- Presence -----------------------------------------------------------------
# Presence can be expensive on large servers; disable if CPU is a concern.
presence:
  enabled: true

# --- Retention ----------------------------------------------------------------
# Message retention (comment out to keep messages forever)
# retention:
#   enabled: true
#   default_policy:
#     min_lifetime: 1d
#     max_lifetime: 1y

# --- Experimental flags -------------------------------------------------------
# None enabled by default. See https://matrix-org.github.io/synapse/latest/usage/configuration/config_documentation.html
experimental_features: {}

# --- Prometheus metrics -------------------------------------------------------
# Exposes Synapse internal metrics for Prometheus scraping on port 9090.
# Bind to 0.0.0.0 so Prometheus can reach it from the host network.
# Path: /_synapse/metrics
enable_metrics: true

listeners:
  - port: 9090
    type: metrics
    bind_addresses: ['0.0.0.0']

# --- Appservices (bridges) ----------------------------------------------------
# YAML files placed in /data/appservices/ are automatically loaded by Synapse.
# Use this to register mautrix bridges (WhatsApp, Telegram, Signal, Discord …).
app_service_config_files: []

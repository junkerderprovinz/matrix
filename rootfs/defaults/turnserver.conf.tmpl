# =============================================================================
# turnserver.conf.tmpl
# Rendered by 10-config.sh via envsubst into /data/turnserver.conf
#
# Variables substituted:
#   ${SERVER_NAME}  — used as realm (TURN realm should match Matrix domain)
#   ${TURN_SECRET}  — shared secret for time-limited HMAC credentials
# =============================================================================

# --- Network ------------------------------------------------------------------
# Listen on all interfaces for TURN/STUN traffic.
listening-port=3478
tls-listening-port=5349

# Bind to all available interfaces
listening-ip=0.0.0.0

# The external IP/hostname clients use to reach this server.
# In most Unraid setups this is the LAN IP of the host.
# If behind NAT with port-forwarding, set this to your public IP.
# Leave commented out to auto-detect (works in most home lab scenarios).
# external-ip=YOUR_PUBLIC_IP

# --- Realm / Identity ---------------------------------------------------------
# The realm is shown to clients during authentication. Conventionally set to
# the Matrix server domain.
realm=${SERVER_NAME}

# --- Authentication -----------------------------------------------------------
# Use HMAC-SHA1 time-limited credentials generated by Synapse.
# Must match the turn_shared_secret in homeserver-overrides.yaml.tmpl.
use-auth-secret
static-auth-secret=${TURN_SECRET}

# --- Security -----------------------------------------------------------------
# Deny relay to RFC-1918 private IP ranges to prevent SSRF attacks.
# These rules prevent a malicious client from using coturn as a relay to
# reach internal network resources.
denied-peer-ip=10.0.0.0-10.255.255.255
denied-peer-ip=172.16.0.0-172.31.255.255
denied-peer-ip=192.168.0.0-192.168.255.255
# Loopback
denied-peer-ip=127.0.0.0-127.255.255.255
# Link-local
denied-peer-ip=169.254.0.0-169.254.255.255
# Carrier-grade NAT
denied-peer-ip=100.64.0.0-100.127.255.255
# IPv6 link-local
denied-peer-ip=fe80::-febf:ffff:ffff:ffff:ffff:ffff:ffff:ffff

# No CLI management interface (reduces attack surface)
no-cli

# --- Logging ------------------------------------------------------------------
# Log to stdout so Docker log driver can capture it.
log-file=stdout

# --- Misc ---------------------------------------------------------------------
# Fingerprint STUN responses for better client compatibility
fingerprint

# Disable long-term credential mechanism (we use short-term HMAC only)
no-auth

# Allow loopback peers only for testing — set to false in production
# (already covered by denied-peer-ip above)

# --- Performance --------------------------------------------------------------
# Reduce memory footprint for a home server with few concurrent calls.
# Each allocation is approximately 64 KB.
max-bps=0
# Limit total relay allocations (0 = unlimited)
total-quota=0
# Per-user relay quota
user-quota=0

# --- TLS (optional) -----------------------------------------------------------
# Uncomment and set paths to your certificates to enable TURN over TLS (port 5349).
# The certificates must be accessible inside the container.
# tls-cert=/data/tls/fullchain.pem
# tls-pkey=/data/tls/privkey.pem
